            ],
            "url": {
              "raw": "{{baseUrl}}/api/clinical/patients/by-code/{{patientCode}}/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinical",
                "patients",
                "by-code",
                "{{patientCode}}",
                "history"
              ]
            }
          },
          "response": []
        }
      ]
