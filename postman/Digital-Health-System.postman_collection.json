    {
      "name": "2. Clinical Workflow",
      "item": [
        {
          "name": "Create Patient (Receptionist)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.patient && data.patient._id) pm.collectionVariables.set('patientId', data.patient._id);",
                  "if (data.patient && data.patient.patientCode) pm.collectionVariables.set('patientCode', data.patient.patientCode);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{receptionToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ravi Kumar\",\n  \"age\": 34,\n  \"gender\": \"male\",\n  \"district\": \"Hyderabad\",\n  \"area\": \"Area A\",\n  \"addressLine\": \"H No 10-2-55, Main Road\",\n  \"contactNumber\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clinical/patients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinical",
                "patients"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Medical Record (Nurse)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.medicalRecord && data.medicalRecord._id) pm.collectionVariables.set('recordId', data.medicalRecord._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{nurseToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentAt\": \"2026-02-21T10:30:00.000Z\",\n  \"symptoms\": [\"fever\", \"body_pain\", \"headache\"],\n  \"vitals\": {\n    \"temperature\": 101.2,\n    \"bpSystolic\": 130,\n    \"bpDiastolic\": 86,\n    \"pulse\": 98,\n    \"spo2\": 96\n  },\n  \"nurseNotes\": \"Patient has high fever for 2 days.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clinical/patients/{{patientId}}/records",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinical",
                "patients",
                "{{patientId}}",
                "records"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Upload Lab Report (Lab)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{labToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"testName\": \"CBC\",\n  \"values\": {\n    \"platelet_count\": 90000,\n    \"wbc\": \"high\",\n    \"crp\": \"positive\"\n  },\n  \"summary\": \"Platelets reduced, inflammatory markers elevated.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clinical/records/{{recordId}}/lab-reports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinical",
                "records",
                "{{recordId}}",
                "lab-reports"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Doctor Diagnosis + Prescription + ML Prediction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diseaseName\": \"Dengue\",\n  \"diagnosisNotes\": \"Confirmed based on symptoms and platelet trend.\",\n  \"doctorSeverity\": \"moderate\",\n  \"prescription\": {\n    \"medicines\": [\n      {\n        \"medicineName\": \"Paracetamol\",\n        \"dosage\": \"650mg\",\n        \"frequency\": \"TID\",\n        \"durationDays\": 5,\n        \"instructions\": \"After food\"\n      }\n    ],\n    \"generalAdvice\": \"Hydration and rest\",\n    \"followUpDate\": \"2026-02-24T10:30:00.000Z\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clinical/records/{{recordId}}/diagnosis",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinical",
                "records",
                "{{recordId}}",
                "diagnosis"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Patient History by Patient Code (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctorToken}}"
